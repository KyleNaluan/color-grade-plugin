<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{6C0F3A1E-4B7D-4E2A-9C3B-8A1D2E5F7A90}</ProjectGuid>
    <RootNamespace>ColorGradeFX</RootNamespace>
    <ProjectName>ColorGradeFX</ProjectName>
    <!-- Pinned per native-phase0-build-config.md: never floating "10.0". -->
    <WindowsTargetPlatformVersion>10.0.26100.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <!-- AE SDK root + GPU switch. Override with /p:AE_SDK_PATH=... and /p:CG_GPU=true. -->
  <PropertyGroup Label="UserMacros">
    <AE_SDK_PATH Condition="'$(AE_SDK_PATH)'==''">C:\dev\AfterEffectsSDK_25.6_61_win\ae25.6_61.64bit.AfterEffectsSDK</AE_SDK_PATH>
    <AE_SDK_EXAMPLES>$(AE_SDK_PATH)\Examples</AE_SDK_EXAMPLES>
    <CG_GPU Condition="'$(CG_GPU)'==''">false</CG_GPU>
    <!-- GPU-only bits, folded into the shared ItemDefinitionGroups below. CG_GPU=true builds
         both DirectX (HAS_HLSL) and CUDA (HAS_CUDA); AE picks the framework at runtime. -->
    <CG_ExtraDefines Condition="'$(CG_GPU)'=='true'">HAS_HLSL=1;HAS_CUDA=1;</CG_ExtraDefines>
    <CG_ExtraIncludes Condition="'$(CG_GPU)'=='true'">$(BOOST_BASE_PATH)\;$(CUDA_SDK_BASE_PATH)\include\;</CG_ExtraIncludes>
    <CG_ExtraLibs Condition="'$(CG_GPU)'=='true'">d3d12.lib;d3dcompiler.lib;dxgi.lib;cudart_static.lib;</CG_ExtraLibs>
    <CG_ExtraLibDirs Condition="'$(CG_GPU)'=='true'">$(CUDA_SDK_BASE_PATH)\lib\x64;</CG_ExtraLibDirs>
    <!-- cudart_static.lib pulls the static CRT (LIBCMT); we use the dynamic CRT (/MD[d]).
         Ignore the static one so the dynamic CRT wins (silences LNK4098, avoids CRT mixing). -->
    <CG_IgnoreLibs Condition="'$(CG_GPU)'=='true'">libcmt.lib;libcmtd.lib;</CG_IgnoreLibs>
    <CG_PiPLDefines Condition="'$(CG_GPU)'=='true'">/D HAS_HLSL=1 </CG_PiPLDefines>
    <!-- nvcc host-compiler flags, matched to the CRT of each config. -->
    <CG_NvccRuntime Condition="'$(Configuration)'=='Debug'">/MDd</CG_NvccRuntime>
    <CG_NvccRuntime Condition="'$(Configuration)'=='Release'">/MD</CG_NvccRuntime>
    <CG_NvccDebug Condition="'$(Configuration)'=='Debug'">-D_DEBUG </CG_NvccDebug>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseOfMfc>false</UseOfMfc>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>MultiByte</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseOfMfc>false</UseOfMfc>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>MultiByte</CharacterSet>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings" />
  <ImportGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="PropertySheets">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <ImportGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="PropertySheets">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <PropertyGroup>
    <OutDir>$(AE_PLUGIN_BUILD_DIR)\</OutDir>
    <IntDir>$(Platform)\$(Configuration)\</IntDir>
    <IgnoreImportLibrary>true</IgnoreImportLibrary>
    <TargetExt>.aex</TargetExt>
    <TargetName>ColorGradeFX</TargetName>
  </PropertyGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <AdditionalIncludeDirectories>$(CG_ExtraIncludes)..\..\third_party\imgui;..\..\third_party\imgui\backends;$(AE_SDK_EXAMPLES)\Headers;$(AE_SDK_EXAMPLES)\Headers\SP;$(AE_SDK_EXAMPLES)\Headers\Win;$(AE_SDK_EXAMPLES)\Resources;$(AE_SDK_EXAMPLES)\Util;$(AE_SDK_EXAMPLES)\GPUUtils;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>$(CG_ExtraDefines)NOMINMAX;MSWindows;WIN32;_DEBUG;_WINDOWS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary>MultiThreadedDebugDLL</RuntimeLibrary>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <WarningLevel>Level3</WarningLevel>
      <TreatWarningAsError>false</TreatWarningAsError>
      <SuppressStartupBanner>true</SuppressStartupBanner>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
      <ProgramDataBaseFileName>$(IntDir)vc$(PlatformToolsetVersion).pdb</ProgramDataBaseFileName>
    </ClCompile>
    <ResourceCompile>
      <PreprocessorDefinitions>_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <Culture>0x0409</Culture>
    </ResourceCompile>
    <Link>
      <OutputFile>$(OutDir)$(TargetName)$(TargetExt)</OutputFile>
      <SuppressStartupBanner>true</SuppressStartupBanner>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <ProgramDatabaseFile>$(IntDir)$(TargetName).pdb</ProgramDatabaseFile>
      <RandomizedBaseAddress>false</RandomizedBaseAddress>
      <ImportLibrary>$(IntDir)$(TargetName).lib</ImportLibrary>
      <TargetMachine>MachineX64</TargetMachine>
      <AdditionalDependencies>$(CG_ExtraLibs)d3d11.lib;d3dcompiler.lib;dxgi.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(CG_ExtraLibDirs)%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <IgnoreSpecificDefaultLibraries>$(CG_IgnoreLibs)%(IgnoreSpecificDefaultLibraries)</IgnoreSpecificDefaultLibraries>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <AdditionalIncludeDirectories>$(CG_ExtraIncludes)..\..\third_party\imgui;..\..\third_party\imgui\backends;$(AE_SDK_EXAMPLES)\Headers;$(AE_SDK_EXAMPLES)\Headers\SP;$(AE_SDK_EXAMPLES)\Headers\Win;$(AE_SDK_EXAMPLES)\Resources;$(AE_SDK_EXAMPLES)\Util;$(AE_SDK_EXAMPLES)\GPUUtils;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>$(CG_ExtraDefines)NOMINMAX;MSWindows;WIN32;NDEBUG;_WINDOWS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <WarningLevel>Level3</WarningLevel>
      <TreatWarningAsError>false</TreatWarningAsError>
      <SuppressStartupBanner>true</SuppressStartupBanner>
    </ClCompile>
    <ResourceCompile>
      <Culture>0x0409</Culture>
    </ResourceCompile>
    <Link>
      <OutputFile>$(OutDir)$(TargetName)$(TargetExt)</OutputFile>
      <SuppressStartupBanner>true</SuppressStartupBanner>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <ProgramDatabaseFile>$(IntDir)$(TargetName).pdb</ProgramDatabaseFile>
      <RandomizedBaseAddress>false</RandomizedBaseAddress>
      <ImportLibrary>$(IntDir)$(TargetName).lib</ImportLibrary>
      <TargetMachine>MachineX64</TargetMachine>
      <AdditionalDependencies>$(CG_ExtraLibs)d3d11.lib;d3dcompiler.lib;dxgi.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(CG_ExtraLibDirs)%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <IgnoreSpecificDefaultLibraries>$(CG_IgnoreLibs)%(IgnoreSpecificDefaultLibraries)</IgnoreSpecificDefaultLibraries>
    </Link>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClInclude Include="..\ColorGrade.h" />
    <ClInclude Include="..\ColorGradeGPU.inc" />
    <ClInclude Include="..\lut\CubeLut.h" />
    <ClInclude Include="..\embedded\EmbeddedLut.h" />
    <ClInclude Include="..\editor\EditorBridge.h" />
    <ClInclude Include="..\editor\PreviewCache.h" />
    <ClInclude Include="..\editor\EditorWindow.h" />
  </ItemGroup>
  <ItemGroup>
    <ClCompile Include="..\ColorGrade.cpp" />
    <ClCompile Include="..\editor\EditorWindow.cpp" />
    <ClCompile Include="$(AE_SDK_EXAMPLES)\Util\Smart_Utils.cpp" />
    <!-- AEGP_SuiteHandler impl: the effect uses AEGP suites via PICA for the editor
         bridge (idle-hook driver + stream writes). Same convention as Smart_Utils. -->
    <ClCompile Include="$(AE_SDK_EXAMPLES)\Util\AEGP_SuiteHandler.cpp" />
    <ClCompile Include="$(AE_SDK_EXAMPLES)\Util\DirectXUtils.cpp" Condition="'$(CG_GPU)'=='true'" />
    <!-- Dear ImGui (vendored, third_party/imgui) + Win32/D3D11 backends: the Phase 3
         editor toolkit. Compiled into the .aex; zero external runtime dependency. -->
    <ClCompile Include="..\..\third_party\imgui\imgui.cpp" />
    <ClCompile Include="..\..\third_party\imgui\imgui_draw.cpp" />
    <ClCompile Include="..\..\third_party\imgui\imgui_tables.cpp" />
    <ClCompile Include="..\..\third_party\imgui\imgui_widgets.cpp" />
    <ClCompile Include="..\..\third_party\imgui\backends\imgui_impl_win32.cpp" />
    <ClCompile Include="..\..\third_party\imgui\backends\imgui_impl_dx11.cpp" />
  </ItemGroup>
  <ItemGroup>
    <!-- Compile the PiPL: preprocess .r -> PiPLtool -> .rc (mirrors the SDK samples). -->
    <CustomBuild Include="..\ColorGradePiPL.r">
      <FileType>Document</FileType>
      <Command>cl $(CG_PiPLDefines)/I "$(AE_SDK_EXAMPLES)\Headers" /EP "..\%(Filename).r" &gt; "$(IntDir)%(Filename).rr"
"$(AE_SDK_EXAMPLES)\Resources\PiPLtool" "$(IntDir)%(Filename).rr" "$(IntDir)%(Filename).rrc"
cl /D "MSWindows" /EP "$(IntDir)%(Filename).rrc" &gt; "$(ProjectDir)%(Filename).rc"</Command>
      <Message>Compiling the PiPL</Message>
      <Outputs>$(ProjectDir)%(Filename).rc;%(Outputs)</Outputs>
    </CustomBuild>
    <!-- GPU only: preprocess the HLSL kernel to a DXC-compiled .cso + root signature. -->
    <CustomBuild Include="..\ColorGrade_Kernel.chlsl" Condition="'$(CG_GPU)'=='true'">
      <FileType>Document</FileType>
      <Command>del /Q "$(ProjectDir)%(Filename).i" 2&gt; nul
"cl.exe" /nologo -D GF_DEVICE_TARGET_HLSL=1 -I"$(BOOST_BASE_PATH)" -I"$(AE_SDK_EXAMPLES)\GPUUtils" /TP /P "%(FullPath)"
python "$(AE_SDK_EXAMPLES)\GPUUtils\ParseHLSL.py" -i "$(ProjectDir)%(Filename).i" -o "$(IntDir)." -e ColorGradeKernel
"$(DXC_SDK_BASE_PATH)\bin\x64\dxc.exe" "$(IntDir)ColorGradeKernel.hlsl" -E main -Fo "$(IntDir)DirectX_Assets\ColorGradeKernel.cso" -Frs "$(IntDir)DirectX_Assets\ColorGradeKernel.rs" -T cs_6_5 -enable-16bit-types -ignore-line-directives</Command>
      <Message>Preprocessing HLSL to CSO/RS for %(Filename).chlsl</Message>
      <Outputs>$(ProjectDir)%(Filename).i;$(IntDir)ColorGradeKernel.hlsl;$(IntDir)DirectX_Assets\ColorGradeKernel.cso;$(IntDir)DirectX_Assets\ColorGradeKernel.rs</Outputs>
      <AdditionalInputs>%(RelativeDir)%(Filename).cu</AdditionalInputs>
    </CustomBuild>
    <!-- GPU only: compile the CUDA kernel with nvcc; the .obj is linked into the .aex.
         -ccbin resolves to the v143 host compiler under VS 2022 (VS 2026 crashes cudafe++;
         see BUILDING.md). -arch=sm_50 emits forward-compatible PTX (JITs onto the sm_86 3090). -->
    <CustomBuild Include="..\ColorGrade_Kernel.cu" Condition="'$(CG_GPU)'=='true'">
      <FileType>Document</FileType>
      <Command>"$(CUDA_SDK_BASE_PATH)\bin\nvcc.exe" $(CG_NvccDebug)-arch=sm_50 -Wno-deprecated-gpu-targets -use_fast_math -m64 -c -ccbin "$(VC_ExecutablePath_x64_x64)" -D_MBCS -Xcompiler $(CG_NvccRuntime),/EHsc,/W3,/nologo,/Zi -I"$(CUDA_SDK_BASE_PATH)\include" -I./ -I"$(AE_SDK_EXAMPLES)\GPUUtils" -I$(BOOST_BASE_PATH) -o "$(IntDir)%(Filename).obj" "$(ProjectDir)..\%(Filename).cu"</Command>
      <Message>Compiling CUDA kernel %(Filename).cu (nvcc)</Message>
      <Outputs>$(IntDir)%(Filename).obj</Outputs>
    </CustomBuild>
  </ItemGroup>
  <ItemGroup>
    <ResourceCompile Include="ColorGradePiPL.rc" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets" />
  <!-- GPU only: DirectX_Assets must ship next to the .aex, or AE silently uses the CPU path. -->
  <Target Name="CopyDirectXAssets" AfterTargets="Build" Condition="'$(CG_GPU)'=='true'">
    <ItemGroup>
      <CGDXAssets Include="$(IntDir)DirectX_Assets\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(CGDXAssets)" DestinationFolder="$(OutDir)DirectX_Assets" SkipUnchangedFiles="false" />
    <Message Importance="high" Text="Copied DirectX_Assets -> $(OutDir)DirectX_Assets" />
  </Target>
</Project>
