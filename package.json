{
  "name": "color-grade-plugin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KyleNaluan/color-grade-plugin.git"
  },
  "scripts": {
    "test": "vitest run",
    "spike": "tsx scripts/spike.ts",
    "author": "tsx scripts/authorTheme.ts",
    "auto-grade": "tsx scripts/autoGrade.ts",
    "check-consistency": "tsx scripts/checkSceneConsistency.ts",
    "agent-bridge": "tsx scripts/agentBridge.ts",
    "gallery": "tsx scripts/genThemeGallery.ts",
    "theme:health": "tsx scripts/themeLibraryReport.ts",
    "dev": "vite",
    "build": "vite build && node scripts/assemble-cep.mjs",
    "lint": "tsx scripts/check-core-purity.ts",
    "typecheck": "tsc",
    "native:gen-lut": "tsx native/scripts/gen-embedded-lut.ts",
    "native:parity": "tsx native/scripts/parity-test.ts",
    "native:core-parity": "tsx native/scripts/core-parity-test.ts",
    "native:editor-test": "tsx native/scripts/editor-bridge-test.ts",
    "native:preview-test": "tsx native/scripts/preview-test.ts",
    "native:analysis-test": "tsx native/scripts/analysis-test.ts",
    "native:scopes-test": "tsx native/scripts/scopes-test.ts",
    "native:agent-test": "tsx native/scripts/agent-bridge-test.ts",
    "native:agent-config": "tsx scripts/writeAgentConfig.ts",
    "native:build": "native/scripts/build.sh"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "fast-png": "^6.4.0",
    "preact": "^10.29.7",
    "tiff": "^7.1.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
